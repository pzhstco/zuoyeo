/**
 * 发起投票页面样式
 */

/* 表单容器 */
.form-container {
  padding: 24rpx;
}

/* 表单项 */
.form-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 表单标签 */
.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

/* 必填标记 */
.required {
  color: #f44336;
  margin-left: 4rpx;
}

/* 选项列表 */
.options-list {
  margin-bottom: 16rpx;
}

/* 选项项 */
.option-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.option-item:last-child {
  margin-bottom: 0;
}

/* 选项输入包装器 */
.option-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
}

/* 选项编号 */
.option-number {
  width: 60rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #4CAF50;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 选项输入框 */
.option-input {
  flex: 1;
  border-radius: 0;
  background: #f8f8f8;
}

/* 删除按钮 */
.option-delete {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 50%;
  margin-left: 16rpx;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.option-delete:active {
  background: #ffeb3b;
}

/* 删除图标 */
.delete-icon {
  font-size: 36rpx;
  color: #999999;
}

/* 添加选项按钮 */
.add-option-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: #f0f9ff;
  border-radius: 12rpx;
  border: 2rpx dashed #4CAF50;
  margin-bottom: 12rpx;
}

.add-icon {
  font-size: 36rpx;
  color: #4CAF50;
  margin-right: 8rpx;
}

.add-text {
  font-size: 28rpx;
  color: #4CAF50;
}

/* 选项提示 */
.options-tip {
  font-size: 24rpx;
  color: #999999;
}

/* 日期时间选择器包装器 */
.date-time-wrapper {
  display: flex;
  gap: 16rpx;
}

.date-input,
.time-input {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.date-input text,
.time-input text {
  font-size: 28rpx;
  color: #666666;
}

/* 提交区域 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.submit-btn[disabled] {
  opacity: 0.6;
}