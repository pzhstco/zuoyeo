<!--index.wxml-->
<!-- 首页投票列表 -->

<!-- 页面容器 -->
<view class="page-container">
  <!-- 头部区域 -->
  <view class="header">
    <view class="header-content">
      <text class="header-title">班级投票助手</text>
      <text class="header-subtitle">让投票更简单</text>
    </view>
  </view>

  <!-- 投票列表 -->
  <view class="vote-list">
    <!-- 列表项 -->
    <view
      wx:for="{{voteList}}"
      wx:key="_id"
      class="vote-item card"
      bindtap="viewVoteDetail"
      data-id="{{item._id}}"
    >
      <!-- 投票标题和状态 -->
      <view class="vote-header">
        <text class="vote-title">{{item.title}}</text>
        <text class="vote-status tag {{item.isExpired ? 'tag-expired' : 'tag-active'}}">
          {{item.statusText}}
        </text>
      </view>

      <!-- 投票描述 -->
      <view class="vote-desc">
        <text class="desc">{{item.description || '暂无描述'}}</text>
      </view>

      <!-- 投票选项预览 -->
      <view class="vote-options">
        <text class="options-label">选项：</text>
        <text class="options-text">
          {{item.options && item.options.length > 0 ? item.options.join('、') : '暂无选项'}}
        </text>
      </view>

      <!-- 投票信息 -->
      <view class="vote-info">
        <view class="info-item">
          <text class="info-icon">&#128100;</text>
          <text class="info-text">{{item.creator || '匿名用户'}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">&#128197;</text>
          <text class="info-text">{{item.formattedTime || '无截止时间'}}</text>
        </view>
        <view class="info-item">
          <text class="info-icon">&#128499;</text>
          <text class="info-text">{{item.voteCount || 0}} 人参与</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{voteList.length === 0 && !isLoading}}" class="empty-state">
      <text class="empty-icon">&#128238;</text>
      <text class="empty-text">{{emptyText}}</text>
    </view>

    <!-- 加载更多提示 -->
    <view wx:if="{{isLoading}}" class="loading-more">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 没有更多提示 -->
    <view wx:if="{{!hasMore && voteList.length > 0}}" class="no-more">
      <text class="no-more-text">- 已加载全部 -</text>
    </view>
  </view>
</view>