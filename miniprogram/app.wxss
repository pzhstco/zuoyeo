/**
 * 全局样式文件
 * 定义小程序通用样式
 */

/* 页面容器基础样式 */
.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 标题样式 */
.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

/* 描述文字样式 */
.desc {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.5;
}

/* 按钮基础样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

/* 主按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #ffffff;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 次要按钮样式 */
.btn-secondary {
  background: #f0f0f0;
  color: #666666;
}

/* 表单输入框样式 */
.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-input:focus {
  background: #ffffff;
  border: 2rpx solid #4CAF50;
}

/* 表单文本域样式 */
.form-textarea {
  width: 100%;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  min-height: 160rpx;
}

.form-textarea:focus {
  background: #ffffff;
  border: 2rpx solid #4CAF50;
}

/* 标签样式 */
.tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.tag-active {
  background: #E8F5E9;
  color: #4CAF50;
}

.tag-expired {
  background: #FFF3E0;
  color: #FF9800;
}